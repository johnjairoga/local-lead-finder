# =============================================================================
# Supabase — Project Settings → API
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# =============================================================================
# Supabase — Project Settings → Database → Connection string
# Transaction pooler (port 6543) for app runtime | Direct (port 5432) for migrations
# ⚠️ URL-encode special chars in password: * → %2A  $ → %24  @ → %40  # → %23
# =============================================================================
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# =============================================================================
# App
# =============================================================================
NODE_ENV="development"
RESULTS_DIR="./results"
POLL_INTERVAL_MS=2000
MAX_CONCURRENT_JOBS=1
STUCK_JOB_MINUTES=10
QUEUE_POLL_INTERVAL_MS=5000
QUEUE_LOCK_TTL_MS=10000

# Playwright (Windows — optional)
# PLAYWRIGHT_BROWSERS_PATH="C:/Users/YourName/AppData/Local/ms-playwright"

# UUID from Supabase → Authentication → Users (required for collections)
SUPABASE_DEFAULT_USER_ID="your-auth-user-uuid"
